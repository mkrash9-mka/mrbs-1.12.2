# Uploaded content (eg company logo) — never execute scripts from this directory.
<IfModule mod_php.c>
  php_flag engine off
</IfModule>

<FilesMatch "\.(php|php\d|phtml|pl|py|cgi|sh)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order Deny,Allow
    Deny from all
  </IfModule>
</FilesMatch>
